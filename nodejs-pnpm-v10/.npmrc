# Supply chain protection for pnpm v10 (>= 10.16)
# pnpm v11 users: see ../nodejs-pnpm-v11/ — build policy moves to pnpm-workspace.yaml

# Minimum release age: blocks packages published less than 7 days ago.
# Value is in minutes: 10080 = 7 days.
# Requires pnpm >= 10.16.
minimumReleaseAge=10080

# Block all lifecycle scripts (preinstall, install, postinstall, prepare).
# Prevents arbitrary code execution during pnpm install.
# To allow a specific package: add it to onlyBuiltDependencies in package.json.
ignore-scripts=true

# Fail if pnpm-lock.yaml would need updating (CI enforcement).
# Use: pnpm install --frozen-lockfile
frozen-lockfile=false

# Block exotic dependency protocols in transitive deps (git://, ssh://, file://).
blockExoticSubdeps=true

# Strict peer dependency resolution.
strict-peer-dependencies=true

# Do not auto-install peer dependencies.
auto-install-peers=false

# Official registry only.
registry=https://registry.npmjs.org/

# Scoped private registry example:
# @myorg:registry=https://npm.internal.company.com/
