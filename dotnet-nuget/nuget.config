<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet configuration for supply chain protection.
  File locations (applied in priority order):
    1. Per-solution: NuGet.Config next to .sln file
    2. User-level:   %AppData%\NuGet\NuGet.Config  (Windows)
                     ~/.config/NuGet/NuGet.Config   (macOS/Linux)
    3. Machine-wide: %ProgramData%\NuGet\Config\    (Windows)
-->
<configuration>

    <!-- Package sources: control which registries are trusted -->
    <packageSources>
        <!-- Clear the default sources first (prevents surprise registry access) -->
        <clear />

        <!-- Official NuGet gallery (or replace with private proxy) -->
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />

        <!-- Internal private feed (uncomment for corporate environments) -->
        <!-- <add key="internal" value="https://pkgs.dev.azure.com/myorg/_packaging/internal/nuget/v3/index.json" /> -->
    </packageSources>

    <!-- Credentials for private feeds (use environment variables, not hardcoded) -->
    <!--
    <packageSourceCredentials>
        <internal>
            <add key="Username" value="%NUGET_USERNAME%" />
            <add key="ClearTextPassword" value="%NUGET_PASSWORD%" />
        </internal>
    </packageSourceCredentials>
    -->

    <!-- Disable package source mapping warnings (strict source mapping below) -->
    <packageSourceMapping>
        <!-- Map all packages to specific sources (prevents dependency confusion) -->
        <!-- Each package pattern resolves from only the listed source -->
        <packageSource key="nuget.org">
            <package pattern="*" />
        </packageSource>
        <!-- For scoped private packages: -->
        <!-- <packageSource key="internal">
            <package pattern="MyOrg.*" />
        </packageSource> -->
    </packageSourceMapping>

    <config>
        <!-- Enable locked mode via RestoreLockedMode=true in csproj (preferred over CLI flag) -->

        <!-- Cache location (default: ~/.nuget/packages) -->
        <!-- <add key="globalPackagesFolder" value="%USERPROFILE%\.nuget\packages" /> -->

        <!-- Disable telemetry -->
        <add key="noProxy" value="" />
    </config>

</configuration>
