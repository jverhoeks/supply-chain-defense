# Supply chain protection for npm

# Minimum release age: blocks packages published less than N days ago.
# Requires npm >= 11.10.0
# IMPORTANT: npm uses DAYS (not minutes — pnpm/yarn use minutes).
# npm config key: min-release-age  (kebab-case, type: Number in days)
# 7 = 7 days, 3 = 3 days, 1 = 1 day
min-release-age=7

# Block all lifecycle scripts (preinstall, postinstall, prepare, etc.)
# This is the single most impactful setting: prevents arbitrary code execution
# during npm install. Re-enable per package only after review.
ignore-scripts=true

# Always audit on install
audit=true

# Disable telemetry / funding nags
fund=false

# Prefer offline cache when available (reduces network attack surface during builds)
prefer-offline=false

# Enforce exact version resolution from package-lock.json in CI
# Use: npm ci  (always frozen by design)

# Lock file version: use v3 (default npm v7+), do not downgrade
lockfile-version=3

# Use the official npm registry only (prevent registry confusion attacks)
registry=https://registry.npmjs.org/

# Scoped packages: route private scopes to internal registry
# @myorg:registry=https://npm.internal.company.com/
