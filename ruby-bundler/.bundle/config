# Bundler project-level configuration
# This file is generated by: bundle config set <key> <value>
# Or written manually. Committed to version control for team consistency.
# User-level config: ~/.bundle/config  (overrides project config)

# Enforce frozen lockfile in production/CI
# Equivalent to: bundle install --frozen
BUNDLE_FROZEN: "true"

# Deployment mode: uses Gemfile.lock exactly, fails if lockfile is outdated
# Use BUNDLE_FROZEN instead in modern Bundler (>= 2.0)
# BUNDLE_DEPLOYMENT: "true"

# Disable post-install messages (reduces noise, not a security setting)
BUNDLE_SILENCE_ROOT_WARNING: "true"

# Custom gem server (replace rubygems.org with internal proxy)
# BUNDLE_MIRROR__HTTPS://RUBYGEMS__ORG/: "https://gems.internal.company.com"
