# pnpm v11: .npmrc is auth and registry settings ONLY.
# Build policy (allowBuilds, strictDepBuilds) and other security settings
# must live in pnpm-workspace.yaml — they are ignored here in v11.

# Minimum release age: still accepted in .npmrc in v11 (enabled by default at 1440 min).
# Set to 10080 to enforce 7-day quarantine explicitly.
minimumReleaseAge=10080

# Official registry only.
registry=https://registry.npmjs.org/

# Scoped private registry example:
# @myorg:registry=https://npm.internal.company.com/

# Auth tokens (use environment variables, never hardcode):
# //registry.npmjs.org/:_authToken=${NPM_TOKEN}
